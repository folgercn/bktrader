APP_NAME=bkTrader-platform
APP_ENV=development
HTTP_ADDR=:8080
STORE_BACKEND=memory
AUTO_MIGRATE=false
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/bktrader?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222
MINUTE_DATA_DIR=.
TICK_DATA_DIR=./dataset/archive
