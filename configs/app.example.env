ORDER_BOOK_FRESHNESS_SECONDS=10
SIGNAL_BAR_FRESHNESS_SECONDS=30
RUNTIME_QUIET_SECONDS=30
PAPER_START_READINESS_TIMEOUT_SECONDS=5
