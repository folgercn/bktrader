APP_NAME=bkTrader-platform
APP_ENV=development
HTTP_ADDR=:8080
STORE_BACKEND=memory
AUTO_MIGRATE=false
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/bktrader?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222
MINUTE_DATA_DIR=.
TICK_DATA_DIR=./dataset/archive
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-password
AUTH_SECRET=change-this-random-secret
AUTH_TOKEN_TTL_MINUTES=720
TRADE_TICK_FRESHNESS_SECONDS=15
ORDER_BOOK_FRESHNESS_SECONDS=10
SIGNAL_BAR_FRESHNESS_SECONDS=30
RUNTIME_QUIET_SECONDS=30
PAPER_START_READINESS_TIMEOUT_SECONDS=5
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_LEVELS=critical,warning

# ETH pretouch probability model lifecycle. live-runner/monolith hot-reload
# validated JSON artifacts and can retrain from audited CSV sources.
BK_PRETOUCH_MODEL_HOT_RELOAD_ENABLED=true
BK_PRETOUCH_MODEL_RELOAD_INTERVAL_SECONDS=30
BK_PRETOUCH_MODEL_RETRAIN_ENABLED=true
BK_PRETOUCH_MODEL_RETRAIN_INTERVAL_SECONDS=86400
BK_PRETOUCH_LEAD_RETRAIN_ENABLED=true
BK_PRETOUCH_T3_OVERLAY_RETRAIN_ENABLED=true
BK_PRETOUCH_MODEL_PATH=data/pretouch_model.json
BK_PRETOUCH_T3_OVERLAY_MODEL_PATH=data/pretouch_t3_overlay_rf_model.json
BK_PRETOUCH_RETRAIN_EVENTS_CSV=research/tick_flow_event_sources/20260514_pretouch_full_window/feature_filtered_seed_events/robust_quality/pretouch_small_pullback_rf_q50_speed300_ge_q10_touch30m_eff300le1.csv
BK_PRETOUCH_T3_OVERLAY_RETRAIN_TRADES_CSV=research/entry_redesign/scripts/output/timing_probability_unified/t3_overlay_rf_cost_sizing_20260520/t3_overlay_rf_cost_base_trades.csv

# Read-only runtime supervisor collection. Compose defaults platform-api to a
# loopback self target so the console Supervisor page can show current status.
SUPERVISOR_TARGETS=api=http://127.0.0.1:8080
SUPERVISOR_STANDALONE_TARGETS=api=http://platform-api:8080
SUPERVISOR_BEARER_TOKEN=change-this-supervisor-probe-token
SUPERVISOR_POLL_INTERVAL_SECONDS=30
SUPERVISOR_HTTP_TIMEOUT_SECONDS=5
SUPERVISOR_APPLICATION_RESTART_ENABLED=false
SUPERVISOR_CONTAINER_RESTART_ENABLED=false
SUPERVISOR_CONTAINER_EXECUTOR=

# Binance live adapter execution mode: mock | rest
BINANCE_FUTURES_EXECUTION_MODE=mock
# Binance market data endpoints used by startup prewarm and signal runtime sessions.
# REST klines are used to warm 1m/4h/1d bars and compute SMA5/MA20/ATR14.
BINANCE_FUTURES_KLINE_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com/ws
# Optional OKX public market data websocket override.
OKX_PUBLIC_WS_URL=wss://ws.okx.com:8443/ws/v5/public

# Frontend Dashboard Polling Intervals
VITE_DASHBOARD_STREAM_ENABLED=true
VITE_DASHBOARD_REALTIME_POLL_MS=5000
VITE_DASHBOARD_REALTIME_SYNC_MS=60000
VITE_DASHBOARD_STATE_REFRESH_MS=300000
VITE_DASHBOARD_CONFIG_POLL_MS=60000
