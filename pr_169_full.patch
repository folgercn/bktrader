+func IntPtrFromEnv(key string) *int {
+	if value := os.Getenv(key); value != "" {
+		if parsed, err := strconv.Atoi(value); err == nil {
+			p := new(int)
+			*p = parsed
+			return p
+		}
+	}
+	return nil
+}
