+func UpdateBinanceRESTLimits(rps, burst, backoffSec int) {
+	if rps > 0 {
+		binanceRESTRequestsPerSecond = rps
+	}
+	if burst > 0 {
+		binanceRESTBurst = burst
+	}
+	if backoffSec > 0 {
