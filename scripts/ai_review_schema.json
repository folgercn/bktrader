{
  "type": "object",
  "additionalProperties": false,
  "required": ["comments"],
  "properties": {
    "comments": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["line", "severity", "message"],
        "properties": {
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "suggestion"]
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          }
        }
      }
    }
  }
}
